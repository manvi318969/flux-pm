# ==========================================================
# YAHAN APNI VALUES DAAL — file ka naam .env rakhna hai
# (Task 1 wala same MongoDB Atlas account reuse kar sakta hai)
# ==========================================================

# MongoDB Atlas connection string (database naam /flux rakhna)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/flux?retryWrites=true&w=majority

# JWT secret — koi bhi lamba random text
JWT_SECRET=flux_super_secret_change_this_to_anything_long_123456

# Server port (Task 1 se alag rakha hai taaki dono saath chal sake)
PORT=5001
